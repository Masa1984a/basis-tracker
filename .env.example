# Anthropic API (画像→数値抽出に使用)
ANTHROPIC_API_KEY=sk-ant-...
# 抽出モデル(コスト重視ならhaiku、精度重視ならsonnetに変更可)
EXTRACT_MODEL=claude-haiku-4-5

# Vercel Postgres / Blob を接続すると自動注入される
# POSTGRES_URL=
# BLOB_READ_WRITE_TOKEN=

# 簡易認証(必ず設定すること。未設定だと誰でもアクセス可能)
BASIC_AUTH_USER=massan
BASIC_AUTH_PASS=change-me

# 任意: Vercel Cron の保護。設定すると /api/basis・/api/market は Authorization: Bearer <CRON_SECRET>
# を要求する(Vercel Cron が自動付与)。未設定なら誰でも実行可。
# CRON_SECRET=

# 任意: basis_session のトークン(refresh_token / privy_access_token)を保存時に AES-256-GCM で
# 暗号化する鍵。設定すると次回保存分から暗号化され、DB だけ漏洩しても復号できなくなる。
# 高エントロピーなランダム値を推奨(生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")。
# 未設定なら従来どおり平文保存。設定後は鍵を失うと既存の暗号化データを復号できなくなるので注意。
# SESSION_ENC_KEY=

# basis.pro の内部APIセッション(refresh_token / session_id 等)は環境変数ではなく
# DB の basis_session テーブルに保存する。種付けは tools/reseed.py で行う(README参照)。

# 任意: Asset サマリ画像を Telegram に投稿する設定。BOT_TOKEN と最低1つの投稿先を設定すると、
# /api/basis(daily cron)の実行ごとに取得済みデータから Asset 要約カード(PNG)を生成し、
# 全ての投稿先へ sendPhoto で投稿する。投稿先が無ければスキップ(telegram フィールドが "skipped")。
# Bot は @BotFather で作成し、各対象チャット/グループに追加してから chat_id を取得する
# (グループ/チャンネルの chat_id は先頭が "-")。値はここではなく Vercel の env に設定すること。
# TELEGRAM_BOT_TOKEN=123456789:AA...
# TELEGRAM_CHAT_ID=-1001234567890
#
# 任意: 主投稿先(TELEGRAM_CHAT_ID)がフォーラム(トピック)型グループの場合、特定トピックへ
# 投稿するなら message_thread_id を指定(未指定なら General)。
# TELEGRAM_THREAD_ID=
#
# 任意: 追加の投稿先(同じ画像を同時投稿)。カンマ/セミコロン/改行区切りで複数指定でき、
# 各要素は "chatId" もしくは "chatId:threadId"(トピックへ投稿する場合)。
# Bot を各グループ/チャンネルに追加しておくこと。例) 別グループへも投稿:
# TELEGRAM_TARGETS=-1009876543210
# 例) 別グループの特定トピック(#42)と、さらに別グループへ:
# TELEGRAM_TARGETS=-1009876543210:42,-1005555555555

# 任意: Asset サマリ画像を Discord チャンネルへ投稿する設定。
# Discord の対象チャンネルで Incoming Webhook を作成し、Webhook URL を Vercel の env に設定する。
# /api/basis(daily cron)の実行ごとに Telegram と同じ Asset 要約カード(PNG)を投稿する。
# URL が無ければスキップ(discord フィールドが "skipped")。
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
#
# 任意: 追加の Discord Webhook URL。カンマ/セミコロン/改行区切りで複数指定できる。
# DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/...,https://discord.com/api/webhooks/...
